# Python-generated files
__pycache__/
*.py[oc]
*.pyo
*.pyd
build/
dist/
wheels/
*.egg-info
*.egg

# Virtual environments and local package cache
.venv
venv/
ENV/
env/
.uv-cache/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# AI tooling
.claude/
.codex/
.cursor/
.windsurf/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Testing and transient outputs
.pytest_cache/
.coverage
htmlcov/
*.log
test_outputs/
output/
output_*/
test_batch/
test_cached/
batch_results/
*_results/

# Temporary development files (keep in scripts/_archive/)
refactor_*.py
delete_*.py
temp_*.py
*_temp.py

# Structure files: ignore by default, keep checked-in examples
*.sdf
*.pdb
!examples/**/*.sdf
!examples/**/*.pdb

# Images: ignore by default, keep checked-in examples
*.png
*.jpg
*.gif
!examples/**/*.png
!examples/**/*.jpg
!examples/**/*.gif

# OS
.DS_Store
Thumbs.db
